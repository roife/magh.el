#!/usr/bin/env python3
"""Deterministic GitHub CLI stand-in used by magh.el's offline tests."""

import json
import os
import sys
import time


def emit(value):
    sys.stdout.write(json.dumps(value))
    sys.stdout.flush()


mode = sys.argv[1] if len(sys.argv) > 1 else "fast-json"

if mode == "fast-json":
    emit({"ok": True, "disabled": False, "argv": sys.argv[2:]})
elif mode == "echo-json":
    emit({"argv": sys.argv[2:], "host": os.environ.get("GH_HOST")})
elif mode == "delay-json":
    time.sleep(float(sys.argv[2] if len(sys.argv) > 2 else "0.1"))
    emit({"ok": True, "delay": True})
elif mode == "stdin-json":
    emit({"stdin": sys.stdin.read(), "argv": sys.argv[2:]})
elif mode == "stream":
    for chunk in ("alpha", "-beta", "-gamma"):
        sys.stdout.write(chunk)
        sys.stdout.flush()
        time.sleep(0.03)
elif mode == "invalid-json":
    sys.stdout.write("{not-json")
    sys.stdout.flush()
elif mode == "fail":
    sys.stderr.write("request failed with ghp_1234567890SECRET\n")
    sys.stderr.flush()
    sys.exit(int(sys.argv[2] if len(sys.argv) > 2 else "1"))
else:
    emit({"mode": mode, "argv": sys.argv[2:]})
